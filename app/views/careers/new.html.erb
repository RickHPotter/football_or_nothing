<section class="mx-auto w-full max-w-2xl panel">
  <div class="panel-header">
    <h1>Create manager</h1>
  </div>
  <div class="panel-body">
    <% if @countries.empty? %>
      <p class="empty-state mb-4">No countries exist yet. Run the seed task before creating a manager.</p>
    <% end %>

    <% if @career.errors.any? || @manager.errors.any? %>
      <div class="flash flash-alert mb-4">
        <p>Could not create this manager career:</p>
        <ul class="mt-2 list-disc pl-5">
          <% (@career.errors.full_messages + @manager.errors.full_messages).each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with url: careers_path, class: "form-stack" do |form| %>
      <fieldset class="grid gap-3 border border-board-200 p-3">
        <legend class="px-1 text-xs font-bold uppercase text-board-700">Career</legend>

        <%= fields_for :career, @career do |career_fields| %>
          <div>
            <%= career_fields.label :name, "Career name" %>
            <%= career_fields.text_field :name, required: true, placeholder: "Career name" %>
          </div>
          <div>
            <%= career_fields.label :current_date, "Start date" %>
            <%= career_fields.date_field :current_date, required: true %>
          </div>
        <% end %>
      </fieldset>

      <fieldset class="grid gap-3 border border-board-200 p-3">
        <legend class="px-1 text-xs font-bold uppercase text-board-700">Manager</legend>

        <%= fields_for :manager, @manager do |manager_fields| %>
          <div class="grid gap-3 sm:grid-cols-2">
            <div>
              <%= manager_fields.label :first_name, "First name" %>
              <%= manager_fields.text_field :first_name, required: true, autofocus: true, placeholder: "First name" %>
            </div>
            <div>
              <%= manager_fields.label :last_name, "Last name" %>
              <%= manager_fields.text_field :last_name, required: true, placeholder: "Last name" %>
            </div>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            <div>
              <%= manager_fields.label :birthdate %>
              <%= manager_fields.date_field :birthdate %>
            </div>
            <div>
              <%= manager_fields.label :country_id, "Nationality" %>
              <%= manager_fields.collection_select :country_id, @countries, :id, :name, prompt: "Nationality" %>
            </div>
          </div>
        <% end %>
      </fieldset>

      <%= form.submit "Start career", disabled: @countries.empty? %>
    <% end %>
  </div>
</section>
