<section class="game-header">
  <div class="game-title-row">
    <div>
      <h1><%= @career.name %></h1>
      <p class="game-subtitle">Current date: <%= @career.current_date %></p>
    </div>

    <% if @current_contract %>
      <%= link_to "Open club dashboard", career_club_path(@career), class: "btn" %>
    <% end %>
  </div>
</section>

<% if @manager %>
  <section class="panel">
    <div class="panel-header">
      <h2>Manager</h2>
      <span class="badge"><%= @manager.status.humanize %></span>
    </div>
    <div class="panel-body stat-grid">
      <div class="stat-tile">
        <div class="stat-label">Name</div>
        <div class="stat-value"><%= [ @manager.first_name, @manager.last_name ].join(" ") %></div>
      </div>
      <div class="stat-tile">
        <div class="stat-label">Nationality</div>
        <div class="stat-value"><%= @manager.country.name %></div>
      </div>
      <div class="stat-tile">
        <div class="stat-label">Reputation</div>
        <div class="stat-value"><%= @manager.reputation %></div>
      </div>
      <div class="stat-tile">
        <div class="stat-label">Career Status</div>
        <div class="stat-value"><%= @manager.status.humanize %></div>
      </div>
    </div>
  </section>

  <% if @current_contract %>
    <div class="game-grid">
      <div class="game-main">
        <section class="panel">
          <div class="panel-header">
            <h2>Next fixture</h2>
          </div>
          <div class="panel-body">
            <% if @next_fixture %>
              <div class="stat-grid">
                <div class="stat-tile">
                  <div class="stat-label">Date</div>
                  <div class="stat-value"><%= @next_fixture.scheduled_on %></div>
                </div>
                <div class="stat-tile">
                  <div class="stat-label">Home</div>
                  <div class="stat-value"><%= @next_fixture.home_club.name %></div>
                </div>
                <div class="stat-tile">
                  <div class="stat-label">Away</div>
                  <div class="stat-value"><%= @next_fixture.away_club.name %></div>
                </div>
                <div class="stat-tile">
                  <div class="stat-label">Round</div>
                  <div class="stat-value"><%= @next_fixture.round %></div>
                </div>
              </div>
              <div class="btn-row mt-3">
                <%= button_to "Advance to match day", advance_career_path(@career) %>
                <%= link_to "Open fixture", career_fixture_path(@career, @next_fixture), class: "btn btn-secondary" %>
              </div>
            <% else %>
              <p class="empty-state">No upcoming fixtures are scheduled.</p>

              <% if @rollover_candidate %>
                <div class="mt-3">
                  <p class="mb-2">Completed season: <strong><%= @rollover_candidate.name %></strong></p>
                  <%= button_to "Start next season", rollover_career_path(@career) %>
                </div>
              <% end %>
            <% end %>
          </div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <h2>Manager seasons</h2>
          </div>
          <div class="panel-body">
            <% if @manager_season_stats.any? %>
              <p class="mb-3 text-sm text-board-700">
                Total:
                <%= @manager_totals[:matches] %> matches,
                <%= @manager_totals[:wins] %> wins,
                <%= @manager_totals[:draws] %> draws,
                <%= @manager_totals[:losses] %> losses,
                <%= @manager_totals[:trophies] %> trophies
              </p>

              <div class="stat-grid mb-3">
                <div class="stat-tile">
                  <div class="stat-label">Matches</div>
                  <div class="stat-value"><%= @manager_totals[:matches] %></div>
                </div>
                <div class="stat-tile">
                  <div class="stat-label">Wins</div>
                  <div class="stat-value"><%= @manager_totals[:wins] %></div>
                </div>
                <div class="stat-tile">
                  <div class="stat-label">Losses</div>
                  <div class="stat-value"><%= @manager_totals[:losses] %></div>
                </div>
                <div class="stat-tile">
                  <div class="stat-label">Trophies</div>
                  <div class="stat-value"><%= @manager_totals[:trophies] %></div>
                </div>
              </div>

              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Competition</th>
                      <th>Club</th>
                      <th>Position</th>
                      <th>Matches</th>
                      <th>W</th>
                      <th>D</th>
                      <th>L</th>
                      <th>Trophies</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% @manager_season_stats.each do |stat| %>
                      <tr>
                        <td><%= stat.tournament_edition.name %></td>
                        <td><%= stat.club.name %></td>
                        <td><%= stat.position || "-" %></td>
                        <td><%= stat.matches %></td>
                        <td><%= stat.wins %></td>
                        <td><%= stat.draws %></td>
                        <td><%= stat.losses %></td>
                        <td><%= stat.trophies %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p class="empty-state">No completed manager seasons yet.</p>
            <% end %>
          </div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <h2>International Competitions</h2>
          </div>
          <div class="panel-body">
            <% if @international_editions.any? %>
              <div class="table-wrap">
                <table>
                  <thead><tr><th>Competition</th><th>Dates</th><th>Status</th><th>Champion</th></tr></thead>
                  <tbody>
                    <% @international_editions.each do |edition| %>
                      <tr>
                        <td><%= edition.name %></td>
                        <td><%= edition.starts_on %> to <%= edition.ends_on %></td>
                        <td><span class="badge"><%= edition.status.humanize %></span></td>
                        <td><%= edition.champion&.name || "-" %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p class="empty-state">No international competitions have been generated yet.</p>
            <% end %>
          </div>
        </section>
      </div>

      <aside class="game-side">
        <section class="panel">
          <div class="panel-header">
            <h2>News</h2>
          </div>
          <div class="panel-body">
            <% if @news_items.any? %>
              <ul class="space-y-2">
                <% @news_items.each do |item| %>
                  <li>
                    <span class="badge"><%= item.category.humanize %></span>
                    <strong><%= item.title %></strong><br>
                    <small><%= item.occurred_on %></small>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="empty-state">No news yet.</p>
            <% end %>
          </div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <h2>Current club</h2>
          </div>
          <div class="panel-body space-y-2">
            <p><span class="stat-label">Club</span><br><strong><%= @current_contract.club.name %></strong></p>
            <p><span class="stat-label">Country</span><br><%= @current_contract.club.country.name %></p>
            <p><span class="stat-label">Wage</span><br><%= number_to_currency(@current_contract.wage) %></p>
            <p><span class="stat-label">Expectations</span><br><%= @current_contract.expectations %></p>
          </div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <h2>Trophies</h2>
          </div>
          <div class="panel-body">
            <% if @trophies.any? %>
              <ul class="space-y-2">
                <% @trophies.each do |trophy| %>
                  <li><span class="badge badge-good"><%= trophy.won_on %></span> <%= trophy.name %> with <%= trophy.club.name %></li>
                <% end %>
              </ul>
            <% else %>
              <p class="empty-state">No trophies won yet.</p>
            <% end %>
          </div>
        </section>
      </aside>
    </div>
    <% else %>
    <section class="panel">
      <div class="panel-header">
        <h2>Available jobs</h2>
        <%= link_to "Browse all clubs", career_browse_clubs_path(@career), class: "btn btn-secondary" %>
      </div>
      <div class="panel-body">
        <%= form_with url: career_path(@career), method: :get, class: "mb-3 grid gap-2 sm:grid-cols-[1fr_auto]" do |form| %>
          <div>
            <%= form.label :country_id, "Country" %>
            <%= form.collection_select :country_id, @job_countries, :id, :name, { selected: @job_country&.id }, class: "field-input" %>
          </div>
          <div class="self-end">
            <%= form.submit "Filter jobs", class: "btn" %>
          </div>
        <% end %>

        <% if @available_clubs.any? %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th></th>
                  <th>Club</th>
                  <th>Country</th>
                  <th>Division</th>
                  <th>Reputation</th>
                  <th>Transfer budget</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @available_clubs.each do |club| %>
                  <tr>
                    <td>
                      <% if club.crest.attached? %>
                        <%= image_tag club.crest, class: "club-crest-sm", alt: "#{club.name} crest" %>
                      <% else %>
                        -
                      <% end %>
                    </td>
                    <td><%= link_to club.name, career_browse_club_path(@career, club) %></td>
                    <td><%= link_to club.country.name, career_country_path(@career, club.country) %></td>
                    <td>
                      <% if (division = @club_divisions[club.id]) %>
                        <%= link_to division.tournament.name, career_tournament_path(@career, division.tournament) %><br>
                        <small><%= division.season_year %></small>
                      <% else %>
                        -
                      <% end %>
                    </td>
                    <td><span class="badge"><%= club.reputation %></span></td>
                    <td><%= number_to_currency(club.club_finance&.transfer_budget || 0) %></td>
                    <td>
                      <%= button_to "Take job", career_manager_contracts_path(@career), params: { club_id: club.id } %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="empty-state">No clubs are willing to hire this manager yet.</p>
        <% end %>
      </div>
    </section>
  <% end %>
<% end %>
