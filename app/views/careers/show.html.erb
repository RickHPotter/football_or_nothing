<h1><%= @career.name %></h1>

<p>Current date: <%= @career.current_date %></p>

<% if @manager %>
  <h2>Manager</h2>

  <p>Name: <%= [ @manager.first_name, @manager.last_name ].join(" ") %></p>
  <p>Nationality: <%= @manager.country.name %></p>
  <p>Reputation: <%= @manager.reputation %></p>
  <p>Status: <%= @manager.status.humanize %></p>

  <% if @current_contract %>
    <h2>Current club</h2>

    <p>Club: <%= @current_contract.club.name %></p>
    <p>Country: <%= @current_contract.club.country.name %></p>
    <p>Wage: <%= number_to_currency(@current_contract.wage) %></p>
    <p>Expectations: <%= @current_contract.expectations %></p>

    <%= link_to "Open club dashboard", career_club_path(@career) %>

    <h2>Next fixture</h2>

    <% if @next_fixture %>
      <p>
        <%= @next_fixture.scheduled_on %>:
        <%= @next_fixture.home_club.name %>
        vs
        <%= @next_fixture.away_club.name %>
      </p>

      <%= button_to "Advance to match day", advance_career_path(@career) %>
    <% else %>
      <p>No upcoming fixtures are scheduled.</p>

      <% if @rollover_candidate %>
        <p>Completed season: <%= @rollover_candidate.name %></p>
        <%= button_to "Start next season", rollover_career_path(@career) %>
      <% end %>
    <% end %>

    <h2>Trophies</h2>

    <% if @trophies.any? %>
      <ul>
        <% @trophies.each do |trophy| %>
          <li><%= trophy.won_on %>: <%= trophy.name %> with <%= trophy.club.name %></li>
        <% end %>
      </ul>
    <% else %>
      <p>No trophies won yet.</p>
    <% end %>

    <h2>Manager seasons</h2>

    <% if @manager_season_stats.any? %>
      <p>
        Total:
        <%= @manager_totals[:matches] %> matches,
        <%= @manager_totals[:wins] %> wins,
        <%= @manager_totals[:draws] %> draws,
        <%= @manager_totals[:losses] %> losses,
        <%= @manager_totals[:trophies] %> trophies
      </p>

      <table>
        <thead>
          <tr>
            <th>Competition</th>
            <th>Club</th>
            <th>Position</th>
            <th>Matches</th>
            <th>W</th>
            <th>D</th>
            <th>L</th>
            <th>Trophies</th>
          </tr>
        </thead>
        <tbody>
          <% @manager_season_stats.each do |stat| %>
            <tr>
              <td><%= stat.tournament_edition.name %></td>
              <td><%= stat.club.name %></td>
              <td><%= stat.position || "-" %></td>
              <td><%= stat.matches %></td>
              <td><%= stat.wins %></td>
              <td><%= stat.draws %></td>
              <td><%= stat.losses %></td>
              <td><%= stat.trophies %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No completed manager seasons yet.</p>
    <% end %>
  <% else %>
    <h2>Available jobs</h2>

    <% if @available_clubs.any? %>
      <table>
        <thead>
          <tr>
            <th>Club</th>
            <th>Country</th>
            <th>Reputation</th>
            <th>Transfer budget</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @available_clubs.each do |club| %>
            <tr>
              <td><%= club.name %></td>
              <td><%= club.country.name %></td>
              <td><%= club.reputation %></td>
              <td><%= number_to_currency(club.club_finance&.transfer_budget || 0) %></td>
              <td>
                <%= button_to "Take job", career_manager_contracts_path(@career), params: { club_id: club.id } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p>No clubs are willing to hire this manager yet.</p>
    <% end %>
  <% end %>
<% end %>
