<h1><%= @career.name %></h1>

<p>Current date: <%= @career.current_date %></p>

<% if @career.manager %>
  <h2>Manager</h2>

  <p>Name: <%= [ @career.manager.first_name, @career.manager.last_name ].join(" ") %></p>
  <p>Nationality: <%= @career.manager.country.name %></p>
  <p>Reputation: <%= @career.manager.reputation %></p>
  <p>Status: <%= @career.manager.status.humanize %></p>
<% end %>
