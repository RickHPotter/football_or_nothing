<h1><%= @club.name %></h1>

<p>Country: <%= @club.country.name %></p>
<p>Reputation: <%= @club.reputation %></p>
<p>Founded: <%= @club.founded_year || "Unknown" %></p>

<h2>Finances</h2>

<% if @finance %>
  <p>Cash balance: <%= number_to_currency(@finance.cash_balance) %></p>
  <p>Transfer budget: <%= number_to_currency(@finance.transfer_budget) %></p>
  <p>Wage budget: <%= number_to_currency(@finance.wage_budget) %></p>
  <p>Debt: <%= number_to_currency(@finance.debt) %></p>
<% else %>
  <p>No financial profile exists for this club.</p>
<% end %>

<h2>Stadium</h2>

<% if @stadium %>
  <p>Name: <%= @stadium.name %></p>
  <p>City: <%= @stadium.city %></p>
  <p>Capacity: <%= number_with_delimiter(@stadium.capacity) %></p>
  <p>Pitch quality: <%= @stadium.pitch_quality %></p>
<% else %>
  <p>No stadium exists for this club.</p>
<% end %>

<h2>Fixtures</h2>

<% if @fixtures.any? %>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Competition</th>
        <th>Round</th>
        <th>Home</th>
        <th>Away</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @fixtures.each do |fixture| %>
        <tr>
          <td><%= fixture.scheduled_on %></td>
          <td><%= fixture.tournament_edition.name %></td>
          <td><%= fixture.round %></td>
          <td><%= link_to fixture.home_club.name, career_fixture_path(@career, fixture) %></td>
          <td><%= link_to fixture.away_club.name, career_fixture_path(@career, fixture) %></td>
          <td><%= fixture.completed? ? fixture.scoreline : fixture.status.humanize %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No fixtures have been scheduled for this club.</p>
<% end %>

<h2>Standings</h2>

<% if @standings.any? %>
  <table>
    <thead>
      <tr>
        <th>Club</th>
        <th>Pts</th>
        <th>P</th>
        <th>W</th>
        <th>D</th>
        <th>L</th>
        <th>GD</th>
      </tr>
    </thead>
    <tbody>
      <% @standings.each do |participation| %>
        <tr>
          <td><%= participation.club.name %></td>
          <td><%= participation.points %></td>
          <td><%= participation.played %></td>
          <td><%= participation.wins %></td>
          <td><%= participation.draws %></td>
          <td><%= participation.losses %></td>
          <td><%= participation.goal_difference %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No standings are available for this club.</p>
<% end %>

<h2>Top scorers</h2>

<% if @top_scorers.any? %>
  <table>
    <thead>
      <tr>
        <th>Player</th>
        <th>Goals</th>
        <th>Apps</th>
      </tr>
    </thead>
    <tbody>
      <% @top_scorers.each do |stat| %>
        <tr>
          <td><%= link_to [ stat.athlete.first_name, stat.athlete.last_name ].join(" "), career_athlete_path(@career, stat.athlete) %></td>
          <td><%= stat.goals %></td>
          <td><%= stat.appearances %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No scorers recorded yet.</p>
<% end %>

<h2>Trophies</h2>

<% if @trophies.any? %>
  <ul>
    <% @trophies.each do |trophy| %>
      <li>
        <%= trophy.won_on %>:
        <%= trophy.name %>
        <% if trophy.manager %>
          under <%= [ trophy.manager.first_name, trophy.manager.last_name ].join(" ") %>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No trophies won yet.</p>
<% end %>

<h2>Club seasons</h2>

<% if @club_season_stats.any? %>
  <table>
    <thead>
      <tr>
        <th>Competition</th>
        <th>Position</th>
        <th>Pts</th>
        <th>P</th>
        <th>W</th>
        <th>D</th>
        <th>L</th>
        <th>GD</th>
        <th>Champion</th>
      </tr>
    </thead>
    <tbody>
      <% @club_season_stats.each do |stat| %>
        <tr>
          <td><%= stat.tournament_edition.name %></td>
          <td><%= stat.position || "-" %></td>
          <td><%= stat.points %></td>
          <td><%= stat.played %></td>
          <td><%= stat.wins %></td>
          <td><%= stat.draws %></td>
          <td><%= stat.losses %></td>
          <td><%= stat.goal_difference %></td>
          <td><%= stat.champion? ? "Yes" : "No" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No completed club seasons yet.</p>
<% end %>

<h2>Squad</h2>

<% if @contracts.any? %>
  <table>
    <thead>
      <tr>
        <th>No.</th>
        <th>Name</th>
        <th>Position</th>
        <th>Ability</th>
        <th>Potential</th>
        <th>Condition</th>
        <th>Wage</th>
      </tr>
    </thead>
    <tbody>
      <% @contracts.each do |contract| %>
        <% athlete = contract.athlete %>
        <tr>
          <td><%= contract.squad_number || "-" %></td>
          <td><%= link_to [ athlete.first_name, athlete.last_name ].join(" "), career_athlete_path(@career, athlete) %></td>
          <td><%= athlete.position.humanize %></td>
          <td><%= athlete.current_ability %></td>
          <td><%= athlete.potential_ability %></td>
          <td><%= athlete.condition %></td>
          <td><%= number_to_currency(contract.wage) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No current squad contracts exist for this club.</p>
<% end %>

<%= link_to "Back to career", career_path(@career) %>
