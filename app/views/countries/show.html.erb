<section class="game-header">
  <div class="game-title-row">
    <div>
      <h1><%= @country.name %></h1>
      <p class="game-subtitle"><%= @country.code %> · Reputation <%= @country.reputation %></p>
    </div>
    <div class="btn-row">
      <%= link_to "All countries", career_countries_path(@career), class: "btn btn-secondary" %>
      <%= link_to "Clubs", career_browse_clubs_path(@career, country_id: @country.id), class: "btn" %>
      <%= link_to "Tournaments", career_tournaments_path(@career, country_id: @country.id), class: "btn" %>
    </div>
  </div>
</section>

<div class="game-grid">
  <div class="game-main">
    <section class="panel">
      <div class="panel-header">
        <h2>Clubs</h2>
        <span class="badge"><%= @country.clubs.count %></span>
      </div>
      <div class="panel-body">
        <% if @clubs.any? %>
          <div class="table-wrap">
            <table>
              <thead><tr><th></th><th>Club</th><th>Rep</th><th>Budget</th><th>Squad</th></tr></thead>
              <tbody>
                <% @clubs.each do |club| %>
                  <tr>
                    <td>
                      <% if club.crest.attached? %>
                        <%= image_tag club.crest, class: "club-crest-sm", alt: "#{club.name} crest" %>
                      <% else %>
                        -
                      <% end %>
                    </td>
                    <td><%= link_to club.name, career_browse_club_path(@career, club) %></td>
                    <td><span class="badge"><%= club.reputation %></span></td>
                    <td><%= number_to_currency(club.club_finance&.transfer_budget || 0) %></td>
                    <td><%= club.current_athlete_contracts.count %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="empty-state">No clubs exist for this country.</p>
        <% end %>
      </div>
    </section>
  </div>

  <aside class="game-side">
    <section class="panel">
      <div class="panel-header">
        <h2>Tournaments</h2>
      </div>
      <div class="panel-body">
        <% if @tournaments.any? %>
          <ul class="space-y-2">
            <% @tournaments.each do |tournament| %>
              <li>
                <%= link_to tournament.name, career_tournament_path(@career, tournament) %><br>
                <small><%= tournament.scope.humanize %> · <%= tournament.format.humanize %></small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-state">No tournaments exist for this country.</p>
        <% end %>
      </div>
    </section>

    <section class="panel">
      <div class="panel-header">
        <h2>Recent Editions</h2>
      </div>
      <div class="panel-body">
        <% if @recent_editions.any? %>
          <ul class="space-y-2">
            <% @recent_editions.each do |edition| %>
              <li>
                <strong><%= edition.name %></strong><br>
                <small><%= edition.starts_on %> to <%= edition.ends_on %></small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-state">No editions recorded yet.</p>
        <% end %>
      </div>
    </section>
  </aside>
</div>
