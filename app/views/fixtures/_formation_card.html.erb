<% managed_lineup = lineup&.club == @club %>
<% substitutions_used = lineup ? @fixture.club_substitution_count(lineup.club) : 0 %>
<% substitution_slots_left = [ 5 - substitutions_used, 0 ].max %>
<% substitution_interactive = managed_lineup && @matchday_session&.paused? && !@fixture.completed? && substitution_slots_left.positive? %>

<section class="panel" <%= "data-controller=lineup-substitution" if substitution_interactive %>>
  <div class="panel-header">
    <h2><%= title %></h2>
    <% if lineup %>
      <span class="badge"><%= lineup.formation %></span>
    <% end %>
  </div>
  <div class="panel-body">
    <% if lineup&.starters&.any? %>
      <% if substitution_interactive %>
        <%= form_with url: substitute_career_fixture_path(@career, @fixture), method: :post, class: "substitution-form", data: { lineup_substitution_target: "form" } do |form| %>
          <%= form.hidden_field :off_lineup_athlete_id, data: { lineup_substitution_target: "offInput" } %>
          <%= form.hidden_field :on_lineup_athlete_id, data: { lineup_substitution_target: "onInput" } %>
          <div class="substitution-toolbar">
            <span data-lineup-substitution-target="preview">Select a substitute and a player to replace.</span>
            <%= form.submit "Confirm substitution", disabled: true, data: { lineup_substitution_target: "submit" } %>
          </div>
        <% end %>
      <% end %>
      <div class="formation-pitch">
        <div class="formation-pitch-field">
          <div class="formation-center-circle"></div>
        </div>
        <% LineupBoard.rows_for(lineup).each do |row| %>
          <div class="formation-row" style="grid-template-columns: repeat(<%= [ row.length, 1 ].max %>, minmax(0, 1fr));">
            <% row.each do |lineup_athlete| %>
              <% athlete = lineup_athlete.athlete %>
              <% player_events = (@events || []).select { |event| event.athlete_id == athlete.id && event.club_id == lineup.club_id } %>
              <div class="formation-player-token" data-lineup-athlete-id="<%= lineup_athlete.id %>" data-player-name="<%= athlete.last_name %>" <%= "data-lineup-substitution-target=starter data-action=dragover->lineup-substitution#allowDrop drop->lineup-substitution#dropOnStarter click->lineup-substitution#selectStarter" if substitution_interactive %>>
                <div class="formation-shirt"><%= lineup_athlete.lineup_slot_label %></div>
                <div class="formation-player-body">
                  <strong><%= athlete.last_name %></strong>
                  <small><%= lineup_athlete.position.humanize %> · <%= lineup_athlete.tactical_role.humanize %></small>
                  <div class="formation-player-meta">
                    <span><%= athlete.condition %>%</span>
                    <% if lineup_athlete.substituted_on_minute %>
                      <span>ON <%= lineup_athlete.substituted_on_minute %>'</span>
                    <% end %>
                    <% if player_events.any?(&:yellow_card?) %>
                      <span>YC</span>
                    <% end %>
                    <% if player_events.any?(&:red_card?) %>
                      <span>RC</span>
                    <% end %>
                    <% if player_events.any?(&:injury?) || athlete.injured? %>
                      <span>INJ</span>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      <% if lineup.bench.any? %>
        <div class="substitution-bench">
          <div class="substitution-bench-header">
            <h3>Substitutes</h3>
            <span class="badge"><%= substitution_slots_left %> left</span>
          </div>
          <div class="substitution-bench-list">
            <% lineup.bench.each do |lineup_athlete| %>
              <% athlete = lineup_athlete.athlete %>
              <% available = lineup_athlete.substituted_on_minute.nil? && lineup_athlete.substituted_off_minute.nil? && athlete.available_on?(@fixture.scheduled_on) %>
              <% interactive_substitute = substitution_interactive && available %>
              <div class="bench-player-token <%= "is-disabled" unless available %>" data-lineup-athlete-id="<%= lineup_athlete.id %>" data-player-name="<%= athlete.last_name %>" draggable="<%= interactive_substitute %>" <%= "data-lineup-substitution-target=substitute data-action=dragstart->lineup-substitution#dragSubstitute click->lineup-substitution#selectSubstitute" if interactive_substitute %>>
                <div class="formation-shirt"><%= lineup_athlete.lineup_slot_label %></div>
                <div class="formation-player-body">
                  <strong><%= athlete.last_name %></strong>
                  <small><%= lineup_athlete.position.humanize %> · <%= lineup_athlete.tactical_role.humanize %></small>
                  <div class="formation-player-meta">
                    <span><%= athlete.condition %>%</span>
                    <% if lineup_athlete.substituted_on_minute %>
                      <span>USED <%= lineup_athlete.substituted_on_minute %>'</span>
                    <% elsif lineup_athlete.substituted_off_minute %>
                      <span>OFF <%= lineup_athlete.substituted_off_minute %>'</span>
                    <% elsif !athlete.available_on?(@fixture.scheduled_on) %>
                      <span>OUT</span>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="empty-state">No lineup selected.</p>
    <% end %>
  </div>
</section>
