<section class="panel">
  <div class="panel-header">
    <h2>Timeline</h2>
  </div>
  <div class="panel-body">
    <% if @events.any? %>
      <ol class="timeline-list">
        <% @events.each do |event| %>
          <% event_badge_class = case event.event_type
                                 when "goal" then "badge-good"
                                 when "yellow_card", "red_card", "injury" then "badge-warn"
                                 else ""
                                 end %>
          <% away_event = event.club_id == @fixture.away_club_id %>
          <li class="timeline-message <%= away_event ? "is-away" : "is-home" %>">
            <div>
              <% if away_event %>
                <span class="badge"><%= event.event_type.humanize %></span>
                <span class="badge <%= event_badge_class %>"><%= event.minute %>'</span>
              <% else %>
                <span class="badge <%= event_badge_class %>"><%= event.minute %>'</span>
                <span class="badge"><%= event.event_type.humanize %></span>
              <% end %>
            </div>
            <p><%= event.description %></p>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="empty-state">No match events recorded.</p>
    <% end %>
  </div>
</section>
