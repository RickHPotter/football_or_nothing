<% lineup_options = @managed_lineup ? (@managed_lineup.starters + @managed_lineup.bench).map { |lineup_athlete| [ "#{lineup_athlete.lineup_slot_label} - #{lineup_athlete.athlete.first_name} #{lineup_athlete.athlete.last_name}", lineup_athlete.id ] } : [] %>

<section class="match-hero">
  <div class="match-team-card">
    <% if @fixture.home_club.crest.attached? %>
      <%= image_tag @fixture.home_club.crest, class: "club-crest-lg" %>
    <% end %>
    <div>
      <div class="match-team-name"><%= @fixture.home_club.name %></div>
      <div class="match-team-meta">Home</div>
    </div>
  </div>

  <div class="match-score-card">
    <h1><%= @fixture.home_club.name %> vs <%= @fixture.away_club.name %></h1>
    <div class="match-scoreline"><%= @fixture.scoreline %></div>
    <p><%= @fixture.tournament_edition.name %> · Round <%= @fixture.round %></p>
    <p><%= @fixture.scheduled_on %> · <%= @fixture.stadium.name %></p>
    <div class="mt-3 flex flex-wrap justify-center gap-2">
      <span class="badge <%= @fixture.completed? ? "badge-good" : "badge-warn" %>"><%= @fixture.status.humanize %></span>
      <% if @matchday_session %>
        <span class="badge">Matchday <%= @matchday_session.status.humanize %> · <%= @matchday_session.minute %>'</span>
      <% elsif @match_state %>
        <span class="badge">Fixture <%= @match_state.clock_status.humanize %> · <%= @match_state.minute %>'</span>
      <% end %>
    </div>

    <div class="mt-4 btn-row justify-center">
      <% if @fixture.completed? %>
        <% if @next_fixture %>
          <%= button_to "Advance to next match", advance_career_path(@career) %>
        <% end %>
      <% elsif @matchday_session&.running? %>
        <%= button_to "Pause Matchday", pause_matchday_career_fixture_path(@career, @fixture), method: :patch %>
      <% elsif @matchday_session&.paused? %>
        <%= button_to "Resume Matchday", resume_matchday_career_fixture_path(@career, @fixture), method: :patch %>
      <% else %>
        <%= button_to "Start Matchday Clock", start_matchday_career_fixture_path(@career, @fixture) %>
        <%= button_to "Simulate Match", simulate_career_fixture_path(@career, @fixture), class: "btn btn-secondary" %>
      <% end %>
    </div>
  </div>

  <div class="match-team-card match-team-card-away">
    <% if @fixture.away_club.crest.attached? %>
      <%= image_tag @fixture.away_club.crest, class: "club-crest-lg" %>
    <% end %>
    <div>
      <div class="match-team-name"><%= @fixture.away_club.name %></div>
      <div class="match-team-meta">Away</div>
    </div>
  </div>
</section>

<div class="matchday-triple">
  <% [ [ "Home Formation", @home_lineup ], [ "Manager Decisions", @managed_lineup ], [ "Away Formation", @away_lineup ] ].each do |title, lineup| %>
    <section class="panel">
      <div class="panel-header">
        <h2><%= title %></h2>
        <% if lineup %>
          <span class="badge"><%= lineup.formation %></span>
        <% end %>
      </div>
      <div class="panel-body">
        <% if title == "Manager Decisions" && !@fixture.completed? %>
          <%= form_with model: @managed_lineup, url: tactics_career_fixture_path(@career, @fixture), method: :patch, class: "form-stack" do |form| %>
            <div>
              <%= form.label :formation %>
              <%= form.select(:formation, LineupTemplate::TEMPLATES.keys.map { |formation| [ formation, formation ] }) %>
            </div>
            <div>
              <%= form.label :mentality %>
              <%= form.select(:mentality, Lineup.mentalities.keys.map { |mentality| [ mentality.humanize, mentality ] }) %>
            </div>
            <%= form.submit "Update tactics" %>
          <% end %>

          <% if @match_state.not_started? %>
            <div class="mt-3">
              <%= button_to "Regenerate lineup", regenerate_lineup_career_fixture_path(@career, @fixture), class: "btn btn-secondary" %>
            </div>

            <% if lineup_options.many? %>
              <%= form_with url: swap_lineup_athletes_career_fixture_path(@career, @fixture), method: :patch, class: "form-stack mt-4" do |form| %>
                <div>
                  <%= form.label :from_lineup_athlete_id, "Slot" %>
                  <%= form.select(:from_lineup_athlete_id, lineup_options) %>
                </div>
                <div>
                  <%= form.label :to_lineup_athlete_id, "Swap with" %>
                  <%= form.select(:to_lineup_athlete_id, lineup_options) %>
                </div>
                <%= form.submit "Swap players" %>
              <% end %>

              <%= form_with url: update_lineup_role_career_fixture_path(@career, @fixture), method: :patch, class: "form-stack mt-4" do |form| %>
                <div>
                  <%= form.label :lineup_athlete_id, "Player role" %>
                  <%= form.select(:lineup_athlete_id, lineup_options) %>
                </div>
                <div>
                  <%= form.label :tactical_role %>
                  <%= form.select(:tactical_role, LineupAthlete.tactical_roles.keys.map { |role| [ role.humanize, role ] }) %>
                </div>
                <%= form.submit "Set role" %>
              <% end %>
            <% end %>
          <% end %>

          <% if @managed_lineup.starters.any? && @managed_lineup.bench.any? %>
            <%= form_with url: substitute_career_fixture_path(@career, @fixture), method: :post, class: "form-stack mt-4" do |form| %>
              <div>
                <%= form.label :off_lineup_athlete_id, "Player off" %>
                <%= form.select(:off_lineup_athlete_id, @managed_lineup.starters.map { |lineup_athlete| [ "#{lineup_athlete.athlete.first_name} #{lineup_athlete.athlete.last_name}", lineup_athlete.id ] }) %>
              </div>
              <div>
                <%= form.label :on_lineup_athlete_id, "Player on" %>
                <%= form.select(:on_lineup_athlete_id, @managed_lineup.bench.where(substituted_on_minute: nil, substituted_off_minute: nil).map { |lineup_athlete| [ "#{lineup_athlete.athlete.first_name} #{lineup_athlete.athlete.last_name}", lineup_athlete.id ] }) %>
              </div>
              <%= form.submit "Make substitution" %>
            <% end %>
          <% end %>
        <% elsif lineup&.starters&.any? %>
          <div class="formation-pitch">
            <% LineupBoard.rows_for(lineup).each do |row| %>
              <div class="formation-row" style="grid-template-columns: repeat(<%= [ row.length, 1 ].max %>, minmax(0, 1fr));">
                <% row.each do |lineup_athlete| %>
                  <div class="formation-player">
                    <span class="formation-slot"><%= lineup_athlete.lineup_slot_label %></span>
                    <strong><%= lineup_athlete.athlete.last_name %></strong>
                    <small><%= lineup_athlete.position.humanize %> · <%= lineup_athlete.tactical_role.humanize %></small>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="empty-state">No lineup selected.</p>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<div class="matchday-triple">
  <% [ [ "#{@fixture.home_club.name} Form", @home_recent_fixtures ], [ "Standings", @standings ], [ "#{@fixture.away_club.name} Form", @away_recent_fixtures ] ].each do |title, collection| %>
    <section class="panel">
      <div class="panel-header">
        <h2><%= title %></h2>
      </div>
      <div class="panel-body">
        <% if title == "Standings" %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Club</th>
                  <th>Pts</th>
                  <th>P</th>
                  <th>GD</th>
                </tr>
              </thead>
              <tbody>
                <% collection.each do |participation| %>
                  <tr>
                    <td><%= participation.club.name %></td>
                    <td><strong><%= participation.points %></strong></td>
                    <td><%= participation.played %></td>
                    <td><%= participation.goal_difference %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% elsif collection.any? %>
          <ol class="grid gap-2">
            <% collection.each do |fixture| %>
              <li>
                <span class="badge <%= fixture.completed? ? "badge-good" : "" %>"><%= fixture.completed? ? fixture.scoreline : fixture.status.humanize %></span>
                <%= fixture.home_club.name %> vs <%= fixture.away_club.name %>
                <br>
                <small><%= fixture.scheduled_on %> · Round <%= fixture.round %></small>
              </li>
            <% end %>
          </ol>
        <% else %>
          <p class="empty-state">No recent matches.</p>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<section class="panel">
  <div class="panel-header">
    <h2>Timeline</h2>
  </div>
  <div class="panel-body">
    <% if @events.any? %>
      <ol class="grid gap-2">
        <% @events.each do |event| %>
          <% event_badge_class = case event.event_type
                                 when "goal" then "badge-good"
                                 when "yellow_card", "red_card", "injury" then "badge-warn"
                                 else ""
                                 end %>
          <li>
            <span class="badge <%= event_badge_class %>"><%= event.minute %>'</span>
            <span class="badge"><%= event.event_type.humanize %></span>
            <%= event.description %>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="empty-state">No match events yet.</p>
    <% end %>
  </div>
</section>

<%= link_to "Back to club", career_club_path(@career), class: "btn btn-secondary" %>
