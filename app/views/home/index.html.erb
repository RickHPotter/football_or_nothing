<section class="game-header">
  <div class="game-title-row">
    <div>
      <h1>Football or Nothing</h1>
      <p class="game-subtitle">A compact football management career.</p>
    </div>

    <% if @career&.manager %>
      <%= link_to "Open career", career_path(@career), class: "btn" %>
    <% else %>
      <%= link_to "Create manager", new_career_path, class: "btn" %>
    <% end %>
  </div>
</section>

<section class="panel">
  <div class="panel-header">
    <h2>Save Slot</h2>
  </div>
  <div class="panel-body">
    <% if @career&.manager %>
      <div class="stat-grid">
        <div class="stat-tile">
          <div class="stat-label">Manager</div>
          <div class="stat-value"><%= [ @career.manager.first_name, @career.manager.last_name ].join(" ") %></div>
        </div>
        <div class="stat-tile">
          <div class="stat-label">Date</div>
          <div class="stat-value"><%= @career.current_date %></div>
        </div>
        <div class="stat-tile">
          <div class="stat-label">Club</div>
          <div class="stat-value"><%= @career.manager.current_club&.name || "Unemployed" %></div>
        </div>
        <div class="stat-tile">
          <div class="stat-label">Status</div>
          <div class="stat-value"><%= @career.manager.status.humanize %></div>
        </div>
      </div>
    <% else %>
      <p class="empty-state">You do not have a manager career yet.</p>
    <% end %>
  </div>
</section>
