<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Football Or Nothing" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Football Or Nothing">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <div class="game-shell">
      <header class="game-topbar">
        <div class="game-topbar-inner">
          <div>
            <%= link_to "Football or Nothing", root_path, class: "game-brand" %>
            <% if Current.user %>
              <div class="text-xs text-board-100">
                <%= Current.user.email_address %>
              </div>
            <% end %>
          </div>

          <% if Current.user %>
            <% nav_career = Current.user.careers.includes(manager: { current_manager_contract: :club }).order(created_at: :desc).first %>
            <nav class="game-nav">
              <%= link_to "Home", root_path %>
              <% if nav_career %>
                <%= link_to "Career", career_path(nav_career) %>
                <% if nav_career.manager&.current_club %>
                  <%= link_to "Club", career_club_path(nav_career) %>
                  <%= link_to "Transfers", career_transfers_path(nav_career) %>
                  <%= link_to "Staff", career_staff_contracts_path(nav_career) %>
                  <%= link_to "Scouting", career_scouting_assignments_path(nav_career) %>
                  <%= link_to "Youth", career_youth_intakes_path(nav_career) %>
                <% end %>
              <% else %>
                <%= link_to "New Career", new_career_path %>
              <% end %>
              <%= button_to "Sign out", session_path, method: :delete %>
            </nav>
          <% end %>
        </div>
      </header>

      <main class="game-page">
        <% if flash[:alert] %>
          <div class="flash flash-alert"><%= flash[:alert] %></div>
        <% end %>

        <% if flash[:notice] %>
          <div class="flash flash-notice"><%= flash[:notice] %></div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
