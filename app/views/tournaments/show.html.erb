<section class="game-header">
  <div class="game-title-row">
    <div>
      <h1><%= @tournament.name %></h1>
      <p class="game-subtitle"><%= @tournament.country.name %> · <%= @tournament.scope.humanize %> · <%= @tournament.format.humanize %></p>
    </div>
    <div class="btn-row">
      <%= link_to "All tournaments", career_tournaments_path(@career), class: "btn btn-secondary" %>
      <%= link_to @tournament.country.name, career_country_path(@career, @tournament.country), class: "btn" %>
    </div>
  </div>
</section>

<div class="game-grid">
  <div class="game-main">
    <section class="panel">
      <div class="panel-header">
        <h2>Standings</h2>
        <% if @current_edition %>
          <span class="badge"><%= @current_edition.season_year %></span>
        <% end %>
      </div>
      <div class="panel-body">
        <% if @standings.any? %>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Club</th><th>Pts</th><th>P</th><th>W</th><th>D</th><th>L</th><th>GD</th></tr></thead>
              <tbody>
                <% @standings.each do |participation| %>
                  <tr>
                    <td><%= link_to participation.club.name, career_browse_club_path(@career, participation.club) %></td>
                    <td><strong><%= participation.points %></strong></td>
                    <td><%= participation.played %></td>
                    <td><%= participation.wins %></td>
                    <td><%= participation.draws %></td>
                    <td><%= participation.losses %></td>
                    <td><%= participation.goal_difference %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="empty-state">No standings are available for this tournament.</p>
        <% end %>
      </div>
    </section>

    <section class="panel">
      <div class="panel-header">
        <h2>Fixtures</h2>
      </div>
      <div class="panel-body">
        <% if @fixtures.any? %>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Date</th><th>Round</th><th>Home</th><th>Away</th><th>Status</th></tr></thead>
              <tbody>
                <% @fixtures.each do |fixture| %>
                  <tr>
                    <td><%= fixture.scheduled_on %></td>
                    <td><%= fixture.round %></td>
                    <td><%= link_to fixture.home_club.name, career_browse_club_path(@career, fixture.home_club) %></td>
                    <td><%= link_to fixture.away_club.name, career_browse_club_path(@career, fixture.away_club) %></td>
                    <td><span class="badge"><%= fixture.completed? ? fixture.scoreline : fixture.status.humanize %></span></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="empty-state">No fixtures are available for this tournament.</p>
        <% end %>
      </div>
    </section>
  </div>

  <aside class="game-side">
    <section class="panel">
      <div class="panel-header">
        <h2>Editions</h2>
      </div>
      <div class="panel-body">
        <% if @editions.any? %>
          <ul class="space-y-2">
            <% @editions.each do |edition| %>
              <li>
                <strong><%= edition.name %></strong><br>
                <small><%= edition.starts_on %> to <%= edition.ends_on %> · <%= edition.status.humanize %></small>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty-state">No editions recorded.</p>
        <% end %>
      </div>
    </section>
  </aside>
</div>
